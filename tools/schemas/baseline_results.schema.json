{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Baseline Results",
  "type": "object",
  "required": ["workloads"],
  "additionalProperties": false,
  "properties": {
    "workloads": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "metrics"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string"},
          "metrics": {
            "type": "object",
            "required": ["ttft_p50", "ttft_p99", "tpot_p50", "tpot_p99"],
            "additionalProperties": false,
            "properties": {
              "ttft_mean": {"type": "number"}, "ttft_p50": {"type": "number"}, "ttft_p99": {"type": "number"},
              "tpot_mean": {"type": "number"}, "tpot_p50": {"type": "number"}, "tpot_p99": {"type": "number"},
              "e2e_mean": {"type": "number"}, "e2e_p50": {"type": "number"}, "e2e_p99": {"type": "number"}
            }
          }
        }
      }
    }
  }
}
