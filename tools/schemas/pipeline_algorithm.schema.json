{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PipelineAlgorithmArtifact",
  "description": "algorithm.json produced by the pipeline extract stage",
  "type": "object",
  "required": ["algorithm_name", "description", "signals", "objective", "scope_validation_passed"],
  "properties": {
    "algorithm_name":          { "type": "string" },
    "description":             { "type": "string" },
    "signals":                 { "type": "array", "items": { "type": "object" } },
    "objective":               { "type": "string" },
    "scope_validation_passed": { "type": "boolean" },
    "scope_notes":             { "type": "array", "items": { "type": "string" } },
    "implementation_hints":    { "type": "array", "items": { "type": "string" } },
    "codebase_patterns":       { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
