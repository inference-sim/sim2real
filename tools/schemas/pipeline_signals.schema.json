{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PipelineSignalsArtifact",
  "description": "signals.json produced by the pipeline extract stage",
  "type": "object",
  "required": ["signals", "coverage_summary", "translation_confidence"],
  "properties": {
    "signals":                { "type": "array", "items": { "type": "object" } },
    "coverage_summary":       { "type": "object" },
    "translation_confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "translation_notes":      { "type": "string" }
  },
  "additionalProperties": true
}
