{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Algorithm Values",
  "description": "BLIS-derived algorithm values generated by Stage 3 Step 8. Combined with config/env_defaults.yaml via merge-values to produce workspace/tekton/values.yaml.",
  "type": "object",
  "required": ["stack", "observe"],
  "additionalProperties": false,
  "properties": {
    "stack": {
      "type": "object",
      "required": ["model", "gaie"],
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "object",
          "required": ["modelName", "helmValues"],
          "additionalProperties": false,
          "properties": {
            "modelName": {
              "type": "string",
              "minLength": 1,
              "description": "HuggingFace model repository name (e.g. Org/Model-7B)"
            },
            "helmValues": {
              "type": "object",
              "required": ["modelArtifacts", "decode"],
              "additionalProperties": false,
              "properties": {
                "modelArtifacts": {
                  "type": "object",
                  "required": ["name", "uri"],
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Model artifact name"
                    },
                    "uri": {
                      "type": "string",
                      "pattern": "^pvc://.*",
                      "description": "PVC URI for model storage, must start with pvc://"
                    }
                  }
                },
                "decode": {
                  "type": "object",
                  "required": ["replicas", "containers"],
                  "additionalProperties": false,
                  "properties": {
                    "replicas": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Number of decode replicas"
                    },
                    "parallelism": {
                      "type": "object",
                      "properties": {
                        "tensor": {
                          "type": "integer",
                          "minimum": 1,
                          "description": "Tensor parallelism degree"
                        }
                      }
                    },
                    "acceleratorTypes": {
                      "type": "object",
                      "properties": {
                        "labelValues": {
                          "type": "array",
                          "items": { "type": "string" },
                          "description": "GPU label values for node selection"
                        }
                      }
                    },
                    "containers": {
                      "type": "array",
                      "minItems": 1,
                      "description": "Container specifications for decode pods",
                      "items": {
                        "type": "object",
                        "required": ["image"],
                        "properties": {
                          "image": {
                            "type": "string",
                            "description": "Container image reference"
                          },
                          "extraConfig": {
                            "type": "object",
                            "description": "Extra vllm or other configuration keys"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "gaie": {
          "type": "object",
          "required": ["treatment"],
          "additionalProperties": false,
          "properties": {
            "treatment": {
              "type": "object",
              "required": ["helmValues"],
              "additionalProperties": false,
              "properties": {
                "helmValues": {
                  "type": "object",
                  "required": ["inferenceExtension"],
                  "additionalProperties": false,
                  "properties": {
                    "inferenceExtension": {
                      "type": "object",
                      "required": ["pluginsCustomConfig"],
                      "additionalProperties": false,
                      "properties": {
                        "pluginsCustomConfig": {
                          "type": "object",
                          "description": "Treatment scorer plugin configuration. Keys are config file names (e.g. custom-plugins.yaml), values are YAML content strings. Dynamic keys are allowed."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "observe": {
      "type": "object",
      "required": ["image", "workloads"],
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "string",
          "description": "Docker image reference for the BLIS observer (e.g. ghcr.io/inference-sim/blis:v0.6.13)"
        },
        "workloads": {
          "type": "array",
          "minItems": 1,
          "description": "Workload definitions from blis_router/workloads/",
          "items": {
            "type": "object",
            "required": ["name", "spec"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "description": "Workload name"
              },
              "source": {
                "type": "string",
                "description": "Path to the source workload YAML file"
              },
              "spec": {
                "type": "string",
                "description": "Workload spec content as a YAML string"
              }
            }
          }
        }
      }
    }
  }
}
